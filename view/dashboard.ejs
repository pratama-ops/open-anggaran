<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Open Anggaran</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-950 text-gray-100 min-h-screen">

  <!-- navbar -->
  <nav class="bg-gray-900 border-b border-gray-800 px-6 py-4 flex items-center justify-between">
    <span class="text-blue-400 font-bold text-xl tracking-tight">Open Anggaran</span>
    <span class="text-gray-400 text-sm">Data Pengadaan Barang Pemerintah</span>
  </nav>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <!-- statistik -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <p class="text-gray-400 text-sm mb-1">Total Paket</p>
        <p class="text-3xl font-bold text-white">
          <%= totalData.toLocaleString('id-ID') %>
        </p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <p class="text-gray-400 text-sm mb-1">Total Nilai Pagu</p>
        <p class="text-3xl font-bold text-blue-400">
          Rp <%= totalPagu.toLocaleString('id-ID') %>
        </p>
      </div>
    </div>

    <!-- tabel -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-800">
        <h2 class="font-semibold text-gray-100">Daftar Paket Pengadaan</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-800 text-gray-400 uppercase text-xs">
            <tr>
              <th class="px-4 py-3 text-left">Nama Paket</th>
              <th class="px-4 py-3 text-left">Pagu (Rp)</th>
              <th class="px-4 py-3 text-left">Metode</th>
              <th class="px-4 py-3 text-left">K/L/PD</th>
              <th class="px-4 py-3 text-left">Lokasi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% pengadaan.forEach(item=> { %>
              <tr class="hover:bg-gray-800 transition-colors">
                <td class="px-4 py-3 text-gray-100 max-w-xs truncate">
                  <a href="/pengadaan/<%= item.id %>" class="hover:text-blue-400 transition-colors">
                    <%= item.nama_paket %>
                  </a>
                </td>
                <td class="px-4 py-3 text-blue-400 font-medium whitespace-nowrap">
                  Rp <%= parseInt(item.pagu_rp).toLocaleString('id-ID') %>
                </td>
                <td class="px-4 py-3 text-gray-100 max-w-xs truncate">
                  <a href="/pengadaan/<%= item.id %>" class="hover:text-blue-400 transition-colors">
                    <%= item.metode %>
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-100 max-w-xs truncate">
                  <a href="/pengadaan/<%= item.id %>" class="hover:text-blue-400 transition-colors">
                    <%= item.klpd %>
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-100 max-w-xs truncate">
                  <a href="/pengadaan/<%= item.id %>" class="hover:text-blue-400 transition-colors">
                    <%= item.lokasi %>
                  </a>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>

      <!-- pagination -->
      <div class="px-6 py-4 border-t border-gray-800 flex items-center justify-between text-sm text-gray-400">
        <span>Halaman <%= halamanSaat %> dari <%= totalHalaman %></span>
        <div class="flex gap-2">
          <% if (halamanSaat> 1) { %>
            <a href="/?page=<%= halamanSaat - 1 %>"
              class="px-3 py-1 bg-gray-800 hover:bg-gray-700 rounded-lg transition-colors">
              ← Sebelumnya
            </a>
            <% } %>
              <% if (halamanSaat < totalHalaman) { %>
                <a href="/?page=<%= halamanSaat + 1 %>"
                  class="px-3 py-1 bg-blue-600 hover:bg-blue-500 rounded-lg text-white transition-colors">
                  Berikutnya →
                </a>
                <% } %>
        </div>
      </div>
    </div>

  </main>

</body>

</html>