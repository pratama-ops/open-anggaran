<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rekapitulasi Analisis — Open Anggaran</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">

  <!-- navbar -->
  <nav class="bg-gray-900 border-b border-gray-800 px-4 md:px-6 py-4 flex items-center justify-between">
    <span class="text-blue-400 font-bold text-lg md:text-xl tracking-tight">Open Anggaran</span>
    <a href="/" class="text-gray-400 text-xs md:text-sm hover:text-white transition-colors">← Kembali</a>
  </nav>

  <main class="max-w-5xl mx-auto px-4 md:px-6 py-6 md:py-8">

    <div class="mb-6">
      <h1 class="text-lg md:text-2xl font-bold text-white mb-1">Rekapitulasi Analisis</h1>
      <p class="text-gray-400 text-sm">Daftar paket pengadaan yang sudah pernah dianalisis AI</p>
    </div>

    <!-- statistik ringkas -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <p class="text-gray-400 text-xs mb-1">Total Dianalisis</p>
        <p class="text-xl font-bold text-white"><%= result.length %></p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <p class="text-gray-400 text-xs mb-1">Perlu Perhatian</p>
        <p class="text-xl font-bold text-yellow-400">
          <%= result.filter(d => d.status === 'perlu_perhatian').length %>
        </p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <p class="text-gray-400 text-xs mb-1">Anomali</p>
        <p class="text-xl font-bold text-red-400">
          <%= result.filter(d => d.status === 'anomali').length %>
        </p>
      </div>
    </div>

    <!-- list hasil analisis -->
    <div class="space-y-3">
      <% if (result.length === 0) { %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-center text-gray-500 text-sm">
          Belum ada paket yang dianalisis.
        </div>
      <% } %>

      <% result.forEach(item => { %>
      <a href="/pengadaan/<%= item.pengadaan_id %>"
         class="block bg-gray-900 border border-gray-800 rounded-xl p-4 hover:bg-gray-800 transition-colors">
        <div class="flex items-start justify-between gap-3 mb-2">
          <p class="text-gray-100 text-sm font-medium leading-snug line-clamp-2">
            <%= item.nama_paket %>
          </p>
          <span class="shrink-0 px-2 py-1 rounded-full text-xs font-semibold
            <%= item.status === 'normal' ? 'bg-green-900 text-green-300' :
                item.status === 'perlu_perhatian' ? 'bg-yellow-900 text-yellow-300' :
                'bg-red-900 text-red-300' %>">
            <%= item.status.replace('_', ' ').toUpperCase() %>
          </span>
        </div>
        <p class="text-blue-400 font-semibold text-sm mb-2">
          Rp <%= parseInt(item.pagu_rp).toLocaleString('id-ID') %>
        </p>
        <p class="text-gray-400 text-xs leading-relaxed line-clamp-2"><%= item.insight %></p>
        <div class="flex gap-4 mt-3 text-xs text-gray-600">
          <span><%= item.klpd %></span>
          <span><%= item.lokasi %></span>
          <span><%= new Date(item.analyzed_at).toLocaleDateString('id-ID') %></span>
        </div>
      </a>
      <% }) %>
    </div>

  </main>

</body>
</html>